<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_inventory" model="ir.ui.view">
        <field name="name">res.config.settings.view.inventory</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block">
                    <h2>Inventory Connector</h2>
                    <div class="row mt16">
                        <div class="col-12 col-lg-6">
                            <div class="o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="inventory_api_url" string="API URL"/>
                                    <div class="text-muted">
                                        URL вашего inventory-service (например https://myapp.railway.app/api/v1/inventory)
                                    </div>
                                    <div class="mt8">
                                        <field name="inventory_api_url" class="o_light_label" style="width: 100%"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
